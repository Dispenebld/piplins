[sub_resource type="GDScript" id="GDScript_qxrlw"]
resource_name = "game.gd"
script/source = "extends Node2D

const SKY_PRESETS = {
	\"afternoon\": {
		\"sky\": \"res://Stage/Backgrounds/sky_afternoon.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_afternoon_1.png\", \"res://Stage/Clouds/cloud_afternoon_2.png\"]
	},
	\"candy\": {
		\"sky\": \"res://Stage/Backgrounds/sky_candy.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_candy_1.png\", \"res://Stage/Clouds/cloud_candy_2.png\"]
	},
	\"dusk\": {
		\"sky\": \"res://Stage/Backgrounds/sky_dusk.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_dusk_1.png\", \"res://Stage/Clouds/cloud_dusk_2.png\"]
	},
	\"grey\": {
		\"sky\": \"res://Stage/Backgrounds/sky_grey.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_grey_1.png\", \"res://Stage/Clouds/cloud_grey_2.png\"]
	},
	\"morning\": {
		\"sky\": \"res://Stage/Backgrounds/sky_morning.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_morning_1.png\", \"res://Stage/Clouds/cloud_morning_2.png\"]
	},
	\"night\": {
		\"sky\": \"res://Stage/Backgrounds/sky_night.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_night_1.png\", \"res://Stage/Clouds/cloud_night_2.png\"]
	},
	\"ourple\": {
		\"sky\": \"res://Stage/Backgrounds/sky_ourple.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_ourple_1.png\", \"res://Stage/Clouds/cloud_ourple_2.png\"]
	},
	\"sunset\": {
		\"sky\": \"res://Stage/Backgrounds/sky_sunset.png\",
		\"clouds\": [\"res://Stage/Clouds/cloud_sunset_1.png\", \"res://Stage/Clouds/cloud_sunset_2.png\"]
	}
}

var raindrop_scene = preload(\"res://Scenes/raindrop.tscn\")
var health = 3
var camera: Camera2D

@onready var background = $Background
@onready var character = $Character
@onready var char_select_ui = $CharacterSelectUI
@onready var rain_spawner = $RainSpawner

func _ready():
	character.visible = false
	character.set_physics_process(false)
	rain_spawner.stop()	# 👈 stop rain at start
	_pick_random_sky()
	char_select_ui.visible = true
	rain_spawner.timeout.connect(_spawn_raindrop)
	
	camera = Camera2D.new()
	camera.position = Vector2(960, 540)
	add_child(camera)

func _pick_random_sky():
	var keys = SKY_PRESETS.keys()
	var random_key = keys[randi() % keys.size()]
	var preset = SKY_PRESETS[random_key]
	background.texture = load(preset[\"sky\"])
	var cloud_list = preset[\"clouds\"]
	var random_cloud = cloud_list[randi() % cloud_list.size()]
	$Clouds.setup(random_cloud)

func on_character_chosen(character_path):
	var sprite = $Character/Sprite2D
	sprite.texture = load(character_path)
	$Character.position = Vector2(960, 540)
	$Character.visible = true
	$Character.set_physics_process(true)
	rain_spawner.start()	# 👈 start rain after character selected

func _spawn_raindrop():
	var drop = raindrop_scene.instantiate()
	drop.position = Vector2(randf_range(0, 1920), -50)
	drop.setup()
	add_child(drop)

func take_damage():
	health -= 1
	print(\"Health: \", health)
	$HUD.remove_heart()
	$HUD.show_damage($Character.position)
	screen_shake()
	if health <= 0:
		game_over()

func screen_shake():
	var tween = create_tween()
	var original = camera.position
	tween.tween_property(camera, \"position\", original + Vector2(randf_range(-15, 15), randf_range(-15, 15)), 0.05)
	tween.tween_property(camera, \"position\", original + Vector2(randf_range(-15, 15), randf_range(-15, 15)), 0.05)
	tween.tween_property(camera, \"position\", original + Vector2(randf_range(-15, 15), randf_range(-15, 15)), 0.05)
	tween.tween_property(camera, \"position\", original, 0.05)

func game_over():
	get_tree().change_scene_to_file(\"res://Scenes/main_menu.tscn\")
"

[sub_resource type="GDScript" id="GDScript_3dryh"]
resource_name = "character.gd"
script/source = "extends CharacterBody2D

var speed = 400

func _ready():
	add_to_group(\"player\")

func _physics_process(_delta):
	var direction = Vector2.ZERO
	if Input.is_key_pressed(KEY_W): direction.y -= 1
	if Input.is_key_pressed(KEY_S): direction.y += 1
	if Input.is_key_pressed(KEY_A): direction.x -= 1
	if Input.is_key_pressed(KEY_D): direction.x += 1
	if direction != Vector2.ZERO:
		direction = direction.normalized()
	velocity = direction * speed
	move_and_slide()
	
	var screen = get_viewport_rect().size
	position.x = clamp(position.x, 0, screen.x)
	position.y = clamp(position.y, 0, screen.y)
"

