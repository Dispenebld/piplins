[sub_resource type="GDScript" id="GDScript_wrm1d"]
resource_name = "character_select.gd"
script/source = "extends CanvasLayer

const CHARACTERS = [
	\"res://Sprites/Characters/character_anchor.png\",
	\"res://Sprites/Characters/character_base.png\",
	\"res://Sprites/Characters/character_nature.png\",
	\"res://Sprites/Characters/character_plasma.png\",
	\"res://Sprites/Characters/character_wound.png\"
]

var selected_character = null
var buttons = []

func _ready():
	_build_ui()

func _build_ui():
	var overlay = ColorRect.new()
	overlay.color = Color(0, 0, 0, 0.6)
	overlay.set_anchors_preset(Control.PRESET_FULL_RECT)
	add_child(overlay)
	
	var panel = Panel.new()
	panel.set_anchors_preset(Control.PRESET_CENTER)
	panel.custom_minimum_size = Vector2(900, 400)
	panel.offset_left = -450
	panel.offset_top = -200
	panel.offset_right = 450
	panel.offset_bottom = 200
	add_child(panel)
	
	var label = Label.new()
	label.text = \"Choose Your Character!\"
	label.set_anchors_preset(Control.PRESET_CENTER_TOP)
	label.offset_left = -300
	label.offset_top = 20
	label.offset_right = 300
	label.offset_bottom = 70
	label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER
	label.add_theme_font_size_override(\"font_size\", 36)
	label.add_theme_color_override(\"font_color\", Color(1, 1, 1))
	panel.add_child(label)
	
	var hbox = HBoxContainer.new()
	hbox.set_anchors_preset(Control.PRESET_CENTER)
	hbox.offset_left = -400
	hbox.offset_top = -80
	hbox.offset_right = 400
	hbox.offset_bottom = 80
	hbox.alignment = BoxContainer.ALIGNMENT_CENTER
	hbox.add_theme_constant_override(\"separation\", 20)
	panel.add_child(hbox)
	
	for i in range(CHARACTERS.size()):
		var btn = TextureButton.new()
		btn.texture_normal = load(CHARACTERS[i])
		btn.custom_minimum_size = Vector2(140, 140)
		btn.stretch_mode = TextureButton.STRETCH_KEEP_ASPECT_CENTERED
		btn.texture_filter = CanvasItem.TEXTURE_FILTER_NEAREST
		btn.pressed.connect(_on_character_selected.bind(i))
		hbox.add_child(btn)
		buttons.append(btn)

func _on_character_selected(index):
	selected_character = CHARACTERS[index]
	print(\"Character selected: \", selected_character)
	get_tree().get_root().get_node(\"Game\").on_character_chosen(selected_character)
	visible = false
"

[sub_resource type="GDScript" id="GDScript_wowpa"]
resource_name = "hud.gd"
script/source = "extends CanvasLayer

var hearts = []

func _ready():
	_build_hearts()

func _build_hearts():
	for i in range(3):
		var heart = Label.new()
		heart.text = \"♥\"
		heart.add_theme_font_size_override(\"font_size\", 50)
		heart.add_theme_color_override(\"font_color\", Color(1, 0.2, 0.2))
		heart.position = Vector2(20 + (i * 60), 20)
		add_child(heart)
		hearts.append(heart)

func remove_heart():
	var active = 0
	for heart in hearts:
		if heart.modulate.a == 1.0:
			active += 1
	if active > 0:
		hearts[active - 1].modulate.a = 0.0

func show_damage(player_position: Vector2):
	var label = Label.new()
	label.text = \"-1\"
	label.add_theme_font_size_override(\"font_size\", 40)
	label.add_theme_color_override(\"font_color\", Color(1, 0.1, 0.1))
	
	# Convert player world position to screen position
	var cam_offset = get_viewport().get_canvas_transform()
	label.position = cam_offset * player_position + Vector2(-20, -60)
	add_child(label)
	
	# Float up and fade out
	var tween = create_tween()
	tween.set_parallel(true)
	tween.tween_property(label, \"position:y\", label.position.y - 60, 0.8)
	tween.tween_property(label, \"modulate:a\", 0.0, 0.8)
	tween.tween_callback(label.queue_free).set_delay(0.8)
"

[sub_resource type="GDScript" id="GDScript_ebmjs"]
resource_name = "clouds.gd"
script/source = "extends Node2D

var cloud_texture_path = \"\"
var cloud_sprite = null

func setup(texture_path):
	cloud_texture_path = texture_path
	_build_cloud()
	_start_float()

func _build_cloud():
	cloud_sprite = Sprite2D.new()
	cloud_sprite.texture = load(cloud_texture_path)
	cloud_sprite.position = Vector2(960, 540)
	cloud_sprite.scale = Vector2(3.6, 3.6)
	add_child(cloud_sprite)
	cloud_sprite.add_to_group(\"clouds\")

func _start_float():
	var tween = create_tween()
	tween.set_loops()
	tween.set_trans(Tween.TRANS_SINE)
	tween.set_ease(Tween.EASE_IN_OUT)
	
	tween.tween_property(cloud_sprite, \"position\", 
		Vector2(960 + 20, 540 + 10), 4.0)
	tween.tween_property(cloud_sprite, \"position\", 
		Vector2(960 - 20, 540 - 10), 4.0)
"

